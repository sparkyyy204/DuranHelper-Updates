<Window x:Class="FSB_helper_C__.GroupEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Group Editor" Height="380" Width="340"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" ResizeMode="NoResize"
        Loaded="Window_Loaded"
        TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType">
    
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI, Inter, sans-serif"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <!-- Тень -->
        <Border Margin="15" Background="{DynamicResource DeepBgBrush}" CornerRadius="12" BorderBrush="{DynamicResource GoldBrush}" BorderThickness="1.5">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="Black" Opacity="0.8"/>
            </Border.Effect>
            <!-- Контент окна -->
            <Grid Margin="0,12,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Заголовок -->
                <Grid Margin="15,0,15,10">
                    <TextBlock Text="РЕДАКТОР ГРУПП" Foreground="{DynamicResource GoldBrush}" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Button Style="{StaticResource ModalCloseBtn}" Click="Close_Click"/>
                </Grid>
                
                <Line Grid.Row="1" X1="15" Y1="0" X2="295" Y2="0" Stroke="{DynamicResource LineBrush}" StrokeThickness="1"/>
                
                <Grid Grid.Row="2" Margin="15,10,15,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Добавить группу -->
                    <Border Background="{DynamicResource SidebarBrush}" BorderBrush="{DynamicResource GreenBrush}" BorderThickness="1" CornerRadius="6" Height="30" Cursor="Hand" MouseLeftButtonUp="AddGroup_Click" Margin="0,0,0,8">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#1f2937"/></Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="+ СОЗДАТЬ ГРУППУ" Foreground="{DynamicResource GreenBrush}" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    
                    <!-- Список групп -->
                    <TextBlock Grid.Row="1" x:Name="lblNoGroups" Text="Групп пока нет..." Foreground="{DynamicResource GrayBrush}" Opacity="0.3" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" Margin="0,30,0,0"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="icGroupList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="bgBorder" Background="{DynamicResource SideBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="6" Margin="0,0,0,5" Height="36"
                                            AllowDrop="True" Drop="Group_Item_Drop"
                                            PreviewMouseLeftButtonDown="Group_Item_PreviewMouseLeftButtonDown"
                                            MouseMove="Group_Item_MouseMove">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#1F242F"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource GoldBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="28"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Точки для перетаскивания -->
                                            <Canvas Width="8" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center" Cursor="SizeAll">
                                                <Ellipse Canvas.Left="0" Canvas.Top="0" Width="2.5" Height="2.5" Fill="{DynamicResource GrayBrush}"/>
                                                <Ellipse Canvas.Left="5" Canvas.Top="0" Width="2.5" Height="2.5" Fill="{DynamicResource GrayBrush}"/>
                                                <Ellipse Canvas.Left="0" Canvas.Top="5" Width="2.5" Height="2.5" Fill="{DynamicResource GrayBrush}"/>
                                                <Ellipse Canvas.Left="5" Canvas.Top="5" Width="2.5" Height="2.5" Fill="{DynamicResource GrayBrush}"/>
                                                <Ellipse Canvas.Left="0" Canvas.Top="10" Width="2.5" Height="2.5" Fill="{DynamicResource GrayBrush}"/>
                                                <Ellipse Canvas.Left="5" Canvas.Top="10" Width="2.5" Height="2.5" Fill="{DynamicResource GrayBrush}"/>
                                            </Canvas>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{DynamicResource TextBrush}" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,6,0">
                                                <Button Style="{StaticResource IconBtn}" Click="Group_Rename_Click" Tag="{Binding Name}" Margin="0,0,3,0" Width="26" Height="26">
                                                    <Path Data="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z" Fill="{DynamicResource TextBrush}" Stretch="Uniform" Width="12" Height="12"/>
                                                </Button>
                                                <Button Style="{StaticResource IconBtn}" Click="Group_Delete_Click" Tag="{Binding Name}" Width="26" Height="26">
                                                    <Path Data="M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19V4Z" Fill="{DynamicResource RedBrush}" Stretch="Uniform" Width="12" Height="12"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
                
                <!-- Подсказка (скрывается когда показан ввод) -->
                <Border x:Name="pnlHint" Grid.Row="3" Background="{DynamicResource MenuHoverBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="6" Height="32" Margin="15,8,15,12">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,0">
                        <TextBlock Text="💡" Foreground="{DynamicResource GoldBrush}" FontSize="14" Margin="0,0,8,0"/>
                        <TextBlock Text="Для изменения порядка перетащите за ⠿" Foreground="{DynamicResource GrayBrush}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Inline ввод имени группы (вместо DialogHost) -->
                <Border x:Name="pnlInlineInput" Grid.Row="3" Background="{DynamicResource BgBrush}" BorderBrush="{DynamicResource GoldBrush}" BorderThickness="1" CornerRadius="6" Margin="15,8,15,12" Visibility="Collapsed">
                    <StackPanel Margin="10,6">
                        <TextBlock x:Name="lblInlineInputTitle" Text="ИМЯ ГРУППЫ" Foreground="{DynamicResource GoldBrush}" FontSize="10" FontWeight="Bold" Margin="0,0,0,4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtInlineInput" Background="{DynamicResource SideBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" FontSize="12" FontFamily="Segoe UI" Padding="6,4" CaretBrush="{DynamicResource TextBrush}" MaxLength="25" KeyDown="InlineInput_KeyDown"/>
                            <Button Grid.Column="1" Content="✓" Foreground="{DynamicResource GreenBrush}" Style="{StaticResource StepDeleteBtn}" FontSize="16" Click="InlineInput_Confirm" Margin="2,0,0,0"/>
                            <Button Grid.Column="2" Content="✕" Foreground="{DynamicResource RedBrush}" Style="{StaticResource StepDeleteBtn}" FontSize="14" Click="InlineInput_Cancel"/>
                        </Grid>
                        <TextBlock x:Name="lblInlineError" Text="" Foreground="#f85149" FontSize="9" Visibility="Collapsed" Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
