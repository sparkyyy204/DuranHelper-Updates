<UserControl x:Class="FSB_helper_C__.BinderEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FSB_helper_C__"
             mc:Ignorable="d" 
             d:DesignHeight="650" d:DesignWidth="1000"
        TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType">
             
    <UserControl.Resources>
        <local:InverseBoolConverter x:Key="InvBool"/>
        
        <DataTemplate x:Key="BindStepTemplate">
            <Grid Height="48" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Canvas Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Panel.ZIndex="-1">
                    <Line x:Name="DashLine" X1="0" Y1="8" X2="0" Y2="58" Stroke="{DynamicResource LineBrush}" StrokeThickness="2" StrokeDashArray="4 4">
                        <Line.Style>
                            <Style TargetType="Line">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLast}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Line.Style>
                    </Line>
                </Canvas>
                <Ellipse Grid.Column="0" Width="16" Height="16" Fill="{DynamicResource BgBrush}" Stroke="{Binding ColorCode}" StrokeThickness="4" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                
                <Border Grid.Column="1" Background="{DynamicResource SideBrush}" CornerRadius="8" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1">
                    <Grid Margin="10,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="60"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        
                        <Grid Grid.Column="0" Height="20" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,10,0">
                            <Border Background="{Binding ColorCode}" Opacity="0.2" CornerRadius="4"/>
                            <TextBlock Text="{Binding desc}" Foreground="{Binding ColorCode}" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" FontSize="10" Margin="12,0"/>
                        </Grid>
                        
                        <Grid Grid.Column="1" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="*"/>    </Grid.ColumnDefinitions>

                            <Border x:Name="InputContainer" Background="{DynamicResource DeepBgBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="4" Height="28">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Grid.ColumnSpan" Value="3"/>
                                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                        <Setter Property="Margin" Value="0,0,10,0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding action}" Value="WAIT">
                                                <Setter Property="Grid.ColumnSpan" Value="1"/>
                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                                <Setter Property="Width" Value="55"/>
                                                <Setter Property="Margin" Value="0"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding action}" Value="PRESS">
                                                <Setter Property="Grid.ColumnSpan" Value="1"/>
                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                                <Setter Property="Width" Value="50"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding action}" Value="KEY">
                                                <Setter Property="Grid.ColumnSpan" Value="1"/>
                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                                <Setter Property="Width" Value="50"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <ScrollViewer x:Name="svSyntax" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" IsHitTestVisible="False">
                                        <TextBlock x:Name="tbSyntax" FontSize="12" FontFamily="Segoe UI" Padding="8,0" VerticalAlignment="Center" HorizontalAlignment="Left">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding action}" Value="KEY"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                                        <DataTrigger Binding="{Binding action}" Value="PRESS"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                                        <DataTrigger Binding="{Binding action}" Value="WAIT"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </ScrollViewer>
                                    
                                    <TextBox x:Name="txtStepVal" Text="{Binding value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                             TextChanged="StepVal_TextChanged" SelectionChanged="StepVal_SelectionChanged" Loaded="StepVal_Loaded" ScrollViewer.ScrollChanged="TxtStepVal_ScrollChanged" 
                                             Background="Transparent" CaretBrush="White" SelectionBrush="#551f6feb" BorderThickness="0" 
                                             FontSize="12" FontFamily="Segoe UI" VerticalContentAlignment="Center">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Setter Property="Padding" Value="8,0"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                                <Setter Property="Foreground" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding action}" Value="KEY"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding action}" Value="PRESS"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding action}" Value="WAIT">
                                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                        <Setter Property="Padding" Value="0"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource GoldBrush}"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                    
                                    <TextBlock Text="Введите..." Foreground="{DynamicResource GrayBrush}" IsHitTestVisible="False" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding Text, ElementName=txtStepVal}" Value=""/>
                                                            <Condition Binding="{Binding Visibility, ElementName=txtStepVal}" Value="Visible"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <TextBlock Text="{Binding value}" Foreground="{DynamicResource RedBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding action}" Value="PRESS"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding action}" Value="KEY"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>
                            
                            <TextBlock Grid.Column="1" Text="мс." Foreground="{DynamicResource GrayBrush}" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" Margin="8,0,10,0" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding action}" Value="WAIT"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal" HorizontalAlignment="Right">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding action}" Value="CHAT"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Border Background="{DynamicResource DeepBgBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="4" Height="26" Width="80">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    
                                    <Border Grid.Column="0" CornerRadius="4">
                                        <Border.Style><Style TargetType="Border"><Setter Property="Background" Value="Transparent"/><Style.Triggers><DataTrigger Binding="{Binding isEnter}" Value="True"><Setter Property="Background" Value="{DynamicResource GoldBrush}"/></DataTrigger></Style.Triggers></Style></Border.Style>
                                    </Border>
                                    
                                    <Border Grid.Column="1" CornerRadius="4">
                                        <Border.Style><Style TargetType="Border"><Setter Property="Background" Value="Transparent"/><Style.Triggers><DataTrigger Binding="{Binding isEnter}" Value="False"><Setter Property="Background" Value="{DynamicResource LineBrush}"/></DataTrigger></Style.Triggers></Style></Border.Style>
                                    </Border>
                                    
                                    <RadioButton Grid.Column="0" Content="Enter" IsChecked="{Binding isEnter, Mode=TwoWay}" GroupName="{Binding Index}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Cursor="Hand">
                                        <RadioButton.Style>
                                            <Style TargetType="RadioButton">
                                                <Setter Property="Foreground" Value="#8b949e"/>
                                                <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="RadioButton"><Border Background="Transparent"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Setter.Value></Setter>
                                                <Style.Triggers><Trigger Property="IsChecked" Value="True"><Setter Property="Foreground" Value="#ffffff"/></Trigger></Style.Triggers>
                                            </Style>
                                        </RadioButton.Style>
                                    </RadioButton>
                                    <RadioButton Grid.Column="1" Content="ЖДАТЬ" IsChecked="{Binding isEnter, Converter={StaticResource InvBool}, Mode=TwoWay}" GroupName="{Binding Index}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Cursor="Hand">
                                        <RadioButton.Style>
                                            <Style TargetType="RadioButton">
                                                <Setter Property="Foreground" Value="#8b949e"/>
                                                <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="RadioButton"><Border Background="Transparent"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Setter.Value></Setter>
                                                <Style.Triggers><Trigger Property="IsChecked" Value="True"><Setter Property="Foreground" Value="#ffffff"/></Trigger></Style.Triggers>
                                            </Style>
                                        </RadioButton.Style>
                                    </RadioButton>
                                </Grid>
                            </Border>
                        </StackPanel>
                        
                        <Button Grid.Column="3" Foreground="#ff7b72" Opacity="0.5" BorderThickness="0" Background="Transparent" HorizontalAlignment="Right" VerticalAlignment="Center" Click="Step_Delete_Click" Tag="{Binding}" Width="30" Height="30">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="Transparent">
                                                    <Path Data="M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19V4Z" 
                                                          Fill="{TemplateBinding Foreground}" Width="14" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="#CC000000">
        <Border x:Name="WinBindEdit" Visibility="Visible" Width="780" Height="560" Background="{DynamicResource BgBrush}" CornerRadius="16" BorderBrush="{DynamicResource GoldBrush}" BorderThickness="1.5" VerticalAlignment="Center" HorizontalAlignment="Center">
<Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="12" Opacity="0.6" Color="Black" Direction="270"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Border BorderBrush="{DynamicResource SideBrush}" BorderThickness="0,0,0,2">
                    <Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="РЕДАКТОР БИНДА" Foreground="{DynamicResource GoldBrush}" FontFamily="Segoe UI" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                            
                            <Button x:Name="btnNewBindInfo" Content="ИНСТРУКЦИЯ" ToolTip="Справка по биндам" Margin="15,0,0,0" Padding="14,6" Background="Transparent" Foreground="{DynamicResource GrayBrush}" BorderBrush="{DynamicResource GrayBrush}" BorderThickness="1.5" FontFamily="Segoe UI" FontSize="11" FontWeight="Bold" Click="Open_Guide" VerticalAlignment="Center" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="#ffffff"/>
                                                <Setter Property="BorderBrush" Value="#ffffff"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                        <Button Style="{StaticResource ModalCloseBtn}" Margin="0,0,20,0" Click="Overlay_Close"/>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2"/>
                        <ColumnDefinition Width="260"/>
                    </Grid.ColumnDefinitions>
                    
                    <Grid Grid.Column="0" Margin="30,20,20,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="ПОСЛЕДОВАТЕЛЬНОСТЬ ДЕЙСТВИЙ" FontFamily="Segoe UI" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource GrayBrush}" Margin="0,0,0,15"/>
                        
                        <Border Grid.Row="1" Margin="-10,0,0,10">
                            <ScrollViewer x:Name="svBindSteps" VerticalScrollBarVisibility="Visible">
                                <ScrollViewer.Resources>
                                    <Style TargetType="ScrollBar">
                                        <Setter Property="Width" Value="4"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ScrollBar">
                                                    <Grid Background="Transparent">
                                                        <Border Background="{DynamicResource SideBrush}" CornerRadius="2" Width="4" HorizontalAlignment="Center"/>
                                                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                                                            <Track.Thumb>
                                                                <Thumb>
                                                                    <Thumb.Template>
                                                                        <ControlTemplate TargetType="Thumb"><Border Background="{DynamicResource GrayBrush}" CornerRadius="2" Width="4"/></ControlTemplate>
                                                                    </Thumb.Template>
                                                                </Thumb>
                                                            </Track.Thumb>
                                                        </Track>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ScrollViewer.Resources>
                                <ItemsControl x:Name="icBindSteps" ItemTemplate="{StaticResource BindStepTemplate}" UseLayoutRounding="True"/>
                            </ScrollViewer>
                        </Border>
                        
                        <Grid Grid.Row="2" Height="50" Margin="0,10,0,0">
                            <Rectangle Fill="{DynamicResource DeepBgBrush}" Stroke="{DynamicResource LineBrush}" StrokeThickness="1" RadiusX="8" RadiusY="8" StrokeDashArray="4 4" SnapsToDevicePixels="True"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                                <TextBlock Text="ДОБАВИТЬ ШАГ:" FontFamily="Segoe UI" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource GrayBrush}" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                
                                <Button Content="+ ЧАТ" Width="135" Height="30" Background="{DynamicResource SideBrush}" Foreground="#3b82f6" BorderBrush="#3b82f6" BorderThickness="1" FontFamily="Segoe UI" FontSize="11" FontWeight="Bold" Click="Step_Add_Chat" Margin="0,0,10,0" Cursor="Hand">
                                    <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
                                </Button>
                                
                                <Button Content="+ КНОПКА" Width="135" Height="30" Background="{DynamicResource SideBrush}" Foreground="{DynamicResource RedBrush}" BorderBrush="{DynamicResource RedBrush}" BorderThickness="1" FontFamily="Segoe UI" FontSize="11" FontWeight="Bold" Click="Step_Add_Key" Cursor="Hand">
                                    <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <Border Grid.Column="1" Background="{DynamicResource SideBrush}"/>

                    <StackPanel Grid.Column="2" Margin="20,20,20,20">
                        
                        <TextBlock Text="НАЗВАНИЕ МАКРОСА" FontFamily="Segoe UI" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource GoldBrush}" Margin="0,0,0,4"/>
                        <Border Height="34" Background="{DynamicResource DeepBgBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="6" Margin="0,0,0,25">
                            <TextBox x:Name="txtBindName" Background="Transparent" Foreground="White" FontFamily="Segoe UI" FontSize="12" BorderThickness="0" Padding="10,0" VerticalContentAlignment="Center" CaretBrush="White"/>
                        </Border>
                        
                        <TextBlock Text="ТИП АКТИВАЦИИ" FontFamily="Segoe UI" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource GoldBrush}" Margin="0,0,0,4"/>
                        <StackPanel Margin="0,0,0,25">
                            <RadioButton x:Name="rbTypeKey" Content="Горячая клавиша" IsChecked="True" Foreground="White" FontFamily="Segoe UI" FontSize="12" Margin="0,0,0,10" Checked="BindType_Changed" Cursor="Hand">
                                <RadioButton.Template>
                                    <ControlTemplate TargetType="RadioButton">
                                        <StackPanel Orientation="Horizontal" Background="Transparent">
                                            <Grid Width="16" Height="16" Margin="0,0,10,0">
                                                <Ellipse x:Name="ring" Stroke="{DynamicResource GoldBrush}" StrokeThickness="2" Fill="Transparent"/>
                                                <Ellipse x:Name="dot" Width="8" Height="8" Fill="{DynamicResource GoldBrush}" Visibility="Visible"/>
                                            </Grid>
                                            <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="False">
                                                <Setter TargetName="dot" Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="ring" Property="Stroke" Value="{DynamicResource GrayBrush}"/>
                                                <Setter TargetName="ring" Property="StrokeThickness" Value="1.5"/>
                                                <Setter Property="Foreground" Value="{DynamicResource GrayBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RadioButton.Template>
                            </RadioButton>
                            
                            <RadioButton x:Name="rbTypeAuto" Content="Автозамена (Текст)" Foreground="{DynamicResource GrayBrush}" FontFamily="Segoe UI" FontSize="12" Checked="BindType_Changed" Cursor="Hand">
                                <RadioButton.Template>
                                    <ControlTemplate TargetType="RadioButton">
                                        <StackPanel Orientation="Horizontal" Background="Transparent">
                                            <Grid Grid.Column="0" Width="16" Height="16" Margin="0,0,10,0">
                                                <Ellipse x:Name="ring" Stroke="{DynamicResource GrayBrush}" StrokeThickness="1.5" Fill="Transparent"/>
                                                <Ellipse x:Name="dot" Width="8" Height="8" Fill="{DynamicResource GoldBrush}" Visibility="Collapsed"/>
                                            </Grid>
                                            <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="dot" Property="Visibility" Value="Visible"/>
                                                <Setter TargetName="ring" Property="Stroke" Value="{DynamicResource GoldBrush}"/>
                                                <Setter TargetName="ring" Property="StrokeThickness" Value="2"/>
                                                <Setter Property="Foreground" Value="#ffffff"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RadioButton.Template>
                            </RadioButton>
                        </StackPanel>

                        <TextBlock Text="КЛАВИША АКТИВАЦИИ" FontFamily="Segoe UI" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource GoldBrush}" Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,40">
                            <Button x:Name="btnBindKey" Height="60" Background="{DynamicResource SideBrush}" Foreground="{DynamicResource GoldBrush}" BorderBrush="{DynamicResource GoldBrush}" BorderThickness="1.5" FontFamily="Segoe UI" FontSize="18" FontWeight="Bold" Click="Bind_SetKey_Editor_Click" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock Text="ТЕКУЩАЯ:" Foreground="{DynamicResource GrayBrush}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                                <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" FontSize="{TemplateBinding FontSize}" FontWeight="{TemplateBinding FontWeight}" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            
                            <Border x:Name="pnlBindAutoTrigger" Visibility="Collapsed" Background="{DynamicResource DeepBgBrush}" BorderThickness="1" BorderBrush="{DynamicResource LineBrush}" CornerRadius="6" Height="34">
                                <Grid>
                                    <TextBlock Text="Текст..." Foreground="{DynamicResource GrayBrush}" VerticalAlignment="Center" Margin="10,0" IsHitTestVisible="False" FontFamily="Segoe UI" FontSize="12">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text.Length, ElementName=txtBindAutoTrigger}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBox x:Name="txtBindAutoTrigger" Background="Transparent" Foreground="White" BorderThickness="0" Padding="10,0" VerticalContentAlignment="Center" FontSize="12" FontFamily="Segoe UI" HorizontalContentAlignment="Left" CaretBrush="White"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <StackPanel VerticalAlignment="Bottom">
                            <Button Content="СОХРАНИТЬ БИНД" Height="45" Background="{DynamicResource GreenBrush}" Foreground="White" BorderThickness="0" FontFamily="Segoe UI" FontSize="13" FontWeight="Bold" Click="Bind_Save_Click" Margin="0,0,0,10" Cursor="Hand">
                                <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="6"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
                                <Button.Style><Style TargetType="Button"><Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.8"/></Trigger></Style.Triggers></Style></Button.Style>
                            </Button>
                            
                            <Button Content="ОТМЕНИТЬ" Height="35" Background="{DynamicResource SideBrush}" Foreground="{DynamicResource GrayBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" FontFamily="Segoe UI" FontSize="12" FontWeight="Bold" Click="Overlay_Close" Cursor="Hand">
                                <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
                                <Button.Style><Style TargetType="Button"><Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Foreground" Value="{DynamicResource TextBrush}"/></Trigger></Style.Triggers></Style></Button.Style>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>