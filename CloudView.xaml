<UserControl x:Class="FSB_helper_C__.CloudView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="650" d:DesignWidth="850" Background="Transparent"
             TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType">
    
    <Grid Margin="30,20,10,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Headers -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="ОБЛАЧНЫЙ КАТАЛОГ" Foreground="{DynamicResource GoldBrush}" FontFamily="Segoe UI" FontWeight="Bold" FontSize="24"/>
            <TextBlock Text="СКАЧИВАНИЕ ГОТОВЫХ КОНФИГУРАЦИЙ И БАЗ ДАННЫХ ДЛЯ ВАШЕГО СЕРВЕРА" Foreground="{DynamicResource GrayBrush}" Opacity="0.8" FontFamily="Segoe UI" FontWeight="Bold" FontSize="12" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Filters Grid -->
        <Grid Grid.Row="1" Margin="0,0,0,15" HorizontalAlignment="Left" Width="830">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="440"/>
            </Grid.ColumnDefinitions>

            <!-- Server Filter -->
            <Border Grid.Column="0" Height="36" CornerRadius="6" Background="{DynamicResource DeepBgBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1">
                <ComboBox x:Name="cmbServer" MaxDropDownHeight="210" Style="{DynamicResource DarkCombo}" Background="Transparent" BorderThickness="0" Foreground="White" FontFamily="Segoe UI" FontSize="12" FontWeight="Bold" Margin="0,0"/>
            </Border>

            <!-- Category Filter -->
            <Border Grid.Column="2" Height="36" CornerRadius="6" Background="{DynamicResource DeepBgBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1">
                <ComboBox x:Name="cmbCategory" MaxDropDownHeight="210" Style="{DynamicResource DarkCombo}" Background="Transparent" BorderThickness="0" Foreground="White" FontFamily="Segoe UI" FontSize="12" FontWeight="Bold" Margin="0,0"/>
            </Border>

            <!-- Search -->
            <Border Grid.Column="4" Height="36" CornerRadius="6" Background="{DynamicResource BgBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1.5">
                <Grid>
                    <TextBlock Text="Поиск по названию или автору..." Foreground="{DynamicResource GrayBrush}" FontFamily="Segoe UI" FontSize="12" VerticalAlignment="Center" Margin="35,0,0,0" IsHitTestVisible="False" x:Name="txtSearchHint"/>
                    <TextBox x:Name="txtSearch" Background="Transparent" BorderThickness="0" Foreground="White" FontFamily="Segoe UI" FontSize="12" VerticalContentAlignment="Center" Margin="30,0,5,0" TextChanged="txtSearch_TextChanged"/>
                    <!-- Search Icon (magnifying glass) -->
                    <Canvas Width="20" Height="20" Margin="10,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left" IsHitTestVisible="False">
                        <Ellipse Canvas.Left="5" Canvas.Top="5" Width="10" Height="10" Stroke="{DynamicResource GrayBrush}" StrokeThickness="2" Fill="Transparent"/>
                        <Line X1="13" Y1="13" X2="18" Y2="18" Stroke="{DynamicResource GrayBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Canvas>
                </Grid>
            </Border>
        </Grid>

        <!-- Loading Overlay (Visible during fetch) -->
        <Border Grid.RowSpan="3" x:Name="LoadingOverlay" Margin="-30,-20,-10,-20" Background="{DynamicResource BgBrush}" Opacity="0.95" Panel.ZIndex="10" Visibility="Collapsed" CornerRadius="0">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid Width="100" Height="100" HorizontalAlignment="Center">
                    <Ellipse Fill="{DynamicResource GoldBrush}" Opacity="0.1" Width="80" Height="80" x:Name="pulseRing1" RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform><ScaleTransform ScaleX="1" ScaleY="1"/></Ellipse.RenderTransform>
                    </Ellipse>
                    <Ellipse Fill="{DynamicResource GoldBrush}" Opacity="0.2" Width="60" Height="60" x:Name="pulseRing2" RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform><ScaleTransform ScaleX="1" ScaleY="1"/></Ellipse.RenderTransform>
                    </Ellipse>
                    <Path Data="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96z" Fill="{DynamicResource GoldBrush}" Width="40" Height="28" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
                <TextBlock x:Name="txtLoadingTitle" Text="ПОДКЛЮЧЕНИЕ К ОБЛАКУ" Foreground="{DynamicResource GoldBrush}" FontFamily="Segoe UI" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" Margin="0,20,0,5"/>
                <TextBlock x:Name="txtLoadingDesc" Text="Синхронизация каталога с сервером..." Foreground="{DynamicResource GrayBrush}" FontFamily="Segoe UI" FontSize="13" HorizontalAlignment="Center" Opacity="0.8"/>
            </StackPanel>
            <Border.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetName="pulseRing1" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="1" To="1.4" Duration="0:0:1.5" AutoReverse="True"/>
                            <DoubleAnimation Storyboard.TargetName="pulseRing1" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="1" To="1.4" Duration="0:0:1.5" AutoReverse="True"/>
                            <DoubleAnimation Storyboard.TargetName="pulseRing1" Storyboard.TargetProperty="Opacity" From="0.1" To="0" Duration="0:0:1.5" AutoReverse="True"/>
                            <DoubleAnimation Storyboard.TargetName="pulseRing2" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="1" To="1.2" Duration="0:0:1.5" AutoReverse="True"/>
                            <DoubleAnimation Storyboard.TargetName="pulseRing2" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="1" To="1.2" Duration="0:0:1.5" AutoReverse="True"/>
                            <DoubleAnimation Storyboard.TargetName="pulseRing2" Storyboard.TargetProperty="Opacity" From="0.2" To="0.05" Duration="0:0:1.5" AutoReverse="True"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>
        </Border>

        <!-- Error View -->
        <Border Grid.Row="2" x:Name="ErrorView" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed" Background="{DynamicResource SideBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="12" Padding="40,30" Margin="0,-40,0,0" Panel.ZIndex="5">
            <StackPanel>
                <Path Data="M12,2C6.48,2 2,6.48 2,12s4.48,10 10,10 10,-4.48 10,-10S17.52,2 12,2z M13,17h-2v-2h2V17z M13,13h-2V7h2V13z" Fill="{DynamicResource RedBrush}" Width="48" Height="48" Stretch="Uniform" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                <TextBlock Text="ОБЛАКО НЕДОСТУПНО" Foreground="{DynamicResource RedBrush}" FontFamily="Segoe UI" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center"/>
                <TextBlock x:Name="txtErrorMsg" Text="Не удалось выполнить загрузку каталога." Foreground="{DynamicResource GrayBrush}" FontFamily="Segoe UI" FontSize="13" HorizontalAlignment="Center" Margin="0,10,0,25" TextAlignment="Center" MaxWidth="250" TextWrapping="Wrap"/>
                
                <Button Content="ПОВТОРИТЬ ЗАГРУЗКУ" Width="200" Height="40" Click="Retry_Click" Cursor="Hand">
                    <Button.Template><ControlTemplate TargetType="Button"><Border x:Name="bg" Background="#1f6feb" CornerRadius="6"><TextBlock Text="{TemplateBinding Content}" Foreground="White" FontFamily="Segoe UI" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="#388bfd"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                </Button>
            </StackPanel>
        </Border>

        <!-- Items Viewer -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,-10,0" Padding="0">
            <ItemsControl x:Name="icCloudList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" Focusable="False" HorizontalAlignment="Left" Width="850"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Card (Bento Box style from oblako.svg) -->
                        <Border Focusable="False" Width="405" Height="110" CornerRadius="12" Background="{DynamicResource SideBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Margin="0,0,20,20">
                            <Canvas Width="405" Height="110" ClipToBounds="True">
                                
                                <!-- Icon Box -->
                                <Border x:Name="IconBg" Canvas.Left="15" Canvas.Top="15" Width="40" Height="40" CornerRadius="8" Background="#1f6feb" Opacity="0.1"/>
                                
                                <Canvas Canvas.Left="15" Canvas.Top="15" Width="40" Height="40">
                                    <!-- Profile Icon (Blue) -->
                                    <Canvas x:Name="IconProfile" Visibility="Visible">
                                        <Path Data="M 20 23 A 10 10 0 1 1 20 23 M 20 13 A 6 6 0 1 0 20 1 A 6 6 0 1 0 20 13 M 8 29 C 8 19 32 19 32 29" Stroke="#1f6feb" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                    </Canvas>

                                    <!-- Laws Icon (Gold) -->
                                    <Canvas x:Name="IconLaws" Visibility="Collapsed">
                                        <Path Data="M 20 0 L 20 30 M 5 0 L 35 0 M 5 0 L 0 13 L 10 13 Z M 35 0 L 30 13 L 40 13 Z M 10 30 L 30 30" Stroke="#d2a65e" StrokeThickness="2" StrokeLineJoin="Round" Fill="Transparent"/>
                                    </Canvas>

                                    <!-- Fines Icon (Green) -->
                                    <Canvas x:Name="IconFines" Visibility="Collapsed">
                                        <Rectangle Canvas.Left="8" Canvas.Top="3" Width="24" Height="28" RadiusX="4" RadiusY="4" Fill="Transparent" Stroke="#2ea043" StrokeThickness="2"/>
                                        <Line X1="13" Y1="9" X2="27" Y2="9" Stroke="#2ea043" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        <Ellipse Canvas.Left="12.5" Canvas.Top="15.5" Width="3" Height="3" Fill="#2ea043"/>
                                        <Ellipse Canvas.Left="18.5" Canvas.Top="15.5" Width="3" Height="3" Fill="#2ea043"/>
                                        <Ellipse Canvas.Left="24.5" Canvas.Top="15.5" Width="3" Height="3" Fill="#2ea043"/>
                                        <Ellipse Canvas.Left="12.5" Canvas.Top="21.5" Width="3" Height="3" Fill="#2ea043"/>
                                        <Ellipse Canvas.Left="18.5" Canvas.Top="21.5" Width="3" Height="3" Fill="#2ea043"/>
                                        <Ellipse Canvas.Left="24.5" Canvas.Top="21.5" Width="3" Height="3" Fill="#2ea043"/>
                                    </Canvas>

                                    <!-- Binds Icon (Purple) -->
                                    <Canvas x:Name="IconBinds" Visibility="Collapsed">
                                        <Rectangle Canvas.Left="5" Canvas.Top="7" Width="30" Height="20" RadiusX="4" RadiusY="4" Fill="Transparent" Stroke="#8957e5" StrokeThickness="2"/>
                                        <Line X1="10" Y1="21" X2="30" Y2="21" Stroke="#8957e5" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        <Ellipse Canvas.Left="9.5" Canvas.Top="11.5" Width="3" Height="3" Fill="#8957e5"/>
                                        <Ellipse Canvas.Left="18.5" Canvas.Top="11.5" Width="3" Height="3" Fill="#8957e5"/>
                                        <Ellipse Canvas.Left="27.5" Canvas.Top="11.5" Width="3" Height="3" Fill="#8957e5"/>
                                    </Canvas>
                                </Canvas>

                                <!-- Header Texts -->
                                <TextBlock Text="{Binding Title}" Canvas.Left="70" Canvas.Top="13" Width="240" Foreground="{DynamicResource TextBrush}" FontFamily="Segoe UI" FontWeight="Bold" FontSize="14" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Description}" Canvas.Left="70" Canvas.Top="34" Width="320" Foreground="{DynamicResource GrayBrush}" FontFamily="Segoe UI" FontSize="11" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>

                                <!-- Server Badge -->
                                <Border x:Name="ServerBg" Canvas.Right="15" Canvas.Top="12" Background="{Binding BadgeBgBrush}" CornerRadius="4" Padding="6,2" Height="18">
                                    <TextBlock x:Name="ServerText" Text="{Binding Server}" Foreground="{Binding BadgeTextBrush}" FontFamily="Segoe UI" FontWeight="Bold" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>

                                <!-- Separator -->
                                <Line X1="15" Y1="65" X2="390" Y2="65" Stroke="{DynamicResource LineBrush}" StrokeDashArray="4 4"/>

                                <!-- Author -->
                                <StackPanel Orientation="Horizontal" Canvas.Left="15" Canvas.Top="85">
                                    <TextBlock Text="Автор: " Foreground="{DynamicResource GrayBrush}" FontFamily="Segoe UI" FontSize="11"/>
                                    <TextBlock Text="{Binding Author}" Foreground="{DynamicResource TextBrush}" FontFamily="Segoe UI" FontSize="11"/>
                                </StackPanel>

                                <!-- Download Button -->
                                <Border Focusable="False" x:Name="BtnInstall" Canvas.Right="15" Canvas.Top="75" Width="125" Height="26" Cursor="Hand" Background="#1f6feb" CornerRadius="6" MouseLeftButtonDown="BtnInstall_Click" Tag="{Binding}">
                                    <TextBlock x:Name="BtnInstallText" Text="⬇ УСТАНОВИТЬ" Foreground="White" FontFamily="Segoe UI" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>

                            </Canvas>
                        </Border>
                        
                        <DataTemplate.Triggers>
                            <!-- Fines -->
                            <DataTrigger Binding="{Binding Type}" Value="fines">
                                <Setter TargetName="IconProfile" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="IconFines" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="IconBg" Property="Background" Value="#2ea043"/>
                            </DataTrigger>
                            <!-- Laws -->
                            <DataTrigger Binding="{Binding Type}" Value="laws">
                                <Setter TargetName="IconProfile" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="IconLaws" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="IconBg" Property="Background" Value="#d2a65e"/>
                            </DataTrigger>
                            <!-- Binds -->
                            <DataTrigger Binding="{Binding Type}" Value="binds">
                                <Setter TargetName="IconProfile" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="IconBinds" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="IconBg" Property="Background" Value="#8957e5"/>
                            </DataTrigger>

                            <!-- Installed State -->
                            <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                                <Setter TargetName="BtnInstall" Property="Background" Value="Transparent"/>
                                <Setter TargetName="BtnInstall" Property="BorderBrush" Value="#2ea043"/>
                                <Setter TargetName="BtnInstall" Property="BorderThickness" Value="1"/>
                                <Setter TargetName="BtnInstall" Property="Cursor" Value="Arrow"/>
                                <Setter TargetName="BtnInstallText" Property="Text" Value="✔ УСТАНОВЛЕНО"/>
                                <Setter TargetName="BtnInstallText" Property="Foreground" Value="#2ea043"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>

            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
