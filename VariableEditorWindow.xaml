<Window x:Class="FSB_helper_C__.VariableEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Variable Editor" Height="420" Width="400"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" ResizeMode="NoResize"
        Loaded="Window_Loaded"
        TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI, Inter, sans-serif"/>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Тень Окна -->
        <Border Margin="15" Background="{DynamicResource DeepBgBrush}" CornerRadius="12" BorderBrush="{DynamicResource GoldBrush}" BorderThickness="1.5">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="Black" Opacity="0.8"/>
            </Border.Effect>

            <Grid Margin="0,12,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок -->
                <Grid Margin="15,0,15,10">
                    <TextBlock Text="ПЕРЕМЕННЫЕ ДЛЯ БИНДОВ" Foreground="{DynamicResource GoldBrush}" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Button Style="{StaticResource ModalCloseBtn}" Click="Close_Click"/>
                </Grid>

                <Line Grid.Row="1" X1="15" Y1="0" X2="370" Y2="0" Stroke="{DynamicResource LineBrush}" StrokeThickness="1"/>

                <StackPanel Grid.Row="2" Margin="15,10,15,0">
                    <Border Background="{DynamicResource SidebarBrush}" BorderBrush="{DynamicResource GreenBrush}" BorderThickness="1" CornerRadius="6" Height="30" Cursor="Hand" MouseLeftButtonUp="AddVariable_Click" Margin="0,0,0,8">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#1f2937"/></Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="+ СОЗДАТЬ ПЕРЕМЕННУЮ" Foreground="{DynamicResource GreenBrush}" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Заголовки таблицы -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="26"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="КЛЮЧ" Foreground="{DynamicResource GrayBrush}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="ТЕКСТ" Foreground="{DynamicResource GrayBrush}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </Grid>

                    <ScrollViewer Height="210" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <!-- Список переменных -->
                            <ItemsControl x:Name="icVariablesList" Margin="0,0,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource SideBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="6" Margin="0,0,0,4" Height="36">
                                            <Grid Margin="6,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="26"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="36"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Ключ (Editable) -->
                                                <Border Grid.Column="0" Background="{DynamicResource InputBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0.5" CornerRadius="4" Height="26" Cursor="IBeam">
                                                    <TextBox Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" Foreground="{DynamicResource GoldBrush}" BorderThickness="0" FontFamily="Segoe UI" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="60" TextAlignment="Center" CaretBrush="{DynamicResource GoldBrush}" LostFocus="VarKey_LostFocus" Tag="{Binding OriginalKey}"/>
                                                </Border>

                                                <!-- Стрелка -->
                                                <Path Grid.Column="1" Data="M0,4 L10,4 L10,1 L15,5.5 L10,10 L10,7 L0,7 Z" Fill="{DynamicResource GrayBrush}" Stretch="Uniform" Width="12" Height="8" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                                <!-- Значение (Editable) -->
                                                <Border Grid.Column="2" Background="{DynamicResource InputBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0.5" CornerRadius="4" Height="26" Cursor="IBeam">
                                                    <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" Foreground="{DynamicResource TextBrush}" BorderThickness="0" FontFamily="Segoe UI" FontWeight="Bold" FontSize="10" VerticalAlignment="Center" CaretBrush="{DynamicResource TextBrush}" Margin="6,0" LostFocus="VarValue_LostFocus" Tag="{Binding Key}"/>
                                                </Border>

                                                <!-- Корзина -->
                                                <Button Grid.Column="3" Style="{StaticResource IconBtn}" HorizontalAlignment="Right" Width="26" Height="26" Click="Vars_Delete_Click" Tag="{Binding Key}">
                                                    <Path Data="M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19V4Z" Fill="{DynamicResource RedBrush}" Stretch="Uniform" Width="12" Height="12"/>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- *ВРЕМЯ* (Системная) -->
                            <Border Background="{DynamicResource BoxBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="6" Height="36" Margin="0,4,0,0">
                                <Grid Margin="6,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="26"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="36"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Ключ (Static) -->
                                    <Border Grid.Column="0" Background="{DynamicResource InputBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0.5" CornerRadius="4" Height="26">
                                        <TextBlock Text="*ВРЕМЯ*" Foreground="{DynamicResource DarkGrayBrush}" FontFamily="Segoe UI" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Стрелка -->
                                    <Path Grid.Column="1" Data="M0,4 L10,4 L10,1 L15,5.5 L10,10 L10,7 L0,7 Z" Fill="#484F58" Stretch="Uniform" Width="12" Height="8" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                    <!-- Значение (Static) -->
                                    <Border Grid.Column="2" Background="Transparent" BorderBrush="#21262D" BorderThickness="1" CornerRadius="4" Height="26">
                                        <TextBlock Text="АВТО (ЧЧ:ММ:СС)" Foreground="#484F58" FontFamily="Segoe UI" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Иконка замка -->
                                    <TextBlock Grid.Column="3" Text="🔒" Foreground="#484F58" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </StackPanel>

                <!-- Подсказка-футер -->
                <Border Grid.Row="3" Background="{DynamicResource MenuHoverBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="6" Height="42" Margin="15,6,15,12">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="💡" Foreground="{DynamicResource GoldBrush}" FontSize="15" Margin="0,0,8,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Пишите ключ в тексте бинда → заменится на значение." Foreground="{DynamicResource TextBrush}" FontSize="11" FontWeight="Bold"/>
                            <TextBlock Text="Звёздочки * добавляются автоматически." Foreground="{DynamicResource GrayBrush}" FontSize="10" Margin="0,1,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
