<UserControl x:Class="FSB_helper_C__.DialogHost"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Visibility="Collapsed">
    <UserControl.Resources>
        <Style x:Key="DarkCombo" TargetType="{x:Type ComboBox}">
            <Setter Property="Background" Value="{DynamicResource SideBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" BorderBrush="{TemplateBinding BorderBrush}" Background="{TemplateBinding Background}" BorderThickness="{TemplateBinding BorderThickness}" Grid.Column="2" Focusable="false" IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border CornerRadius="4" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                            <Path x:Name="Arrow" Stroke="{DynamicResource GrayBrush}" StrokeThickness="2" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0" Data="M0,0 L5,5 L10,0" RenderTransformOrigin="0.5,0.5">
                                                <Path.RenderTransform><RotateTransform Angle="0"/></Path.RenderTransform>
                                            </Path>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Trigger.EnterActions>
                                                    <BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetName="Arrow" Storyboard.TargetProperty="(Path.RenderTransform).(RotateTransform.Angle)" To="180" Duration="0:0:0.2"/></Storyboard></BeginStoryboard>
                                                </Trigger.EnterActions>
                                                <Trigger.ExitActions>
                                                    <BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetName="Arrow" Storyboard.TargetProperty="(Path.RenderTransform).(RotateTransform.Angle)" To="0" Duration="0:0:0.2"/></Storyboard></BeginStoryboard>
                                                </Trigger.ExitActions>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter HorizontalAlignment="Left" Margin="{TemplateBinding Padding}" VerticalAlignment="Center" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border x:Name="DropDownBorder" Background="{DynamicResource SideBrush}" BorderThickness="1" BorderBrush="{DynamicResource LineBrush}" Margin="0,4,0,0" CornerRadius="6" MinWidth="{TemplateBinding ActualWidth}">
                                    <Border.Effect><DropShadowEffect RenderingBias="Performance" BlurRadius="10" ShadowDepth="4" Opacity="0.3" Color="Black"/></Border.Effect>
                                    <ScrollViewer x:Name="DropDownScrollViewer" Margin="4" SnapsToDevicePixels="True" MaxHeight="210" CanContentScroll="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                        <ItemsPresenter x:Name="ItemsPresenter" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="{DynamicResource MenuHoverBrush}"/><Setter Property="Foreground" Value="{DynamicResource GoldBrush}"/></Trigger>
                            <Trigger Property="IsSelected" Value="True"><Setter TargetName="Bd" Property="Background" Value="#1AFFFFFF"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="Foreground" Value="{DynamicResource GoldBrush}"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="Overlay" Background="#99000000">
        <!-- ═══════════════════════════════════════════ -->
        <!-- INFO DIALOG (одна кнопка ПОНЯТНО)          -->
        <!-- ═══════════════════════════════════════════ -->
        <Grid x:Name="WinInfo" Visibility="Collapsed" Width="380" VerticalAlignment="Center" HorizontalAlignment="Center">
            <!-- Shadow Layer -->
            <Border CornerRadius="12" Background="Transparent" BorderThickness="0" Margin="1.5">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="Black" Opacity="0.8"/>
                </Border.Effect>
            </Border>
            <!-- Background Layer -->
            <Border x:Name="WinInfoBg" CornerRadius="12" BorderThickness="1.5" Background="{DynamicResource DeepBgBrush}" BorderBrush="{DynamicResource GoldBrush}">
                <Grid>
                    <StackPanel Margin="0,12,0,20">
                        <!-- Header -->
                        <Grid Margin="15,0,15,10">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock x:Name="lblInfoIconError" Text="⚠️" FontFamily="Segoe UI Emoji" FontSize="15" Foreground="#feca2f" VerticalAlignment="Center" Margin="0,0,8,0" Visibility="Collapsed"/>
                                <TextBlock x:Name="lblInfoIconSuccess" Text="✅" FontFamily="Segoe UI Emoji" FontSize="15" VerticalAlignment="Center" Margin="0,0,8,0" Visibility="Collapsed"/>
                                <TextBlock x:Name="lblInfoTitle" Text="ОШИБКА" Foreground="{DynamicResource GoldBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                        <!-- Separator -->
                        <Line X1="15" Y1="0" X2="365" Y2="0" Stroke="{DynamicResource LineBrush}" StrokeThickness="1"/>
                        
                        <StackPanel Margin="25,15,25,0">
                            <!-- Label -->
                            <TextBlock x:Name="lblInfoLabel" Text="СИСТЕМНОЕ СООБЩЕНИЕ:" Foreground="{DynamicResource RedBrush}" FontFamily="Segoe UI" FontSize="11" FontWeight="Bold" Opacity="0.8" Margin="0,0,0,8"/>
                            <!-- Message box -->
                            <Border x:Name="infoMsgBorder" Background="{DynamicResource SideBrush}" CornerRadius="6" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Opacity="1" Padding="15,12" MinHeight="50">
                                <TextBlock x:Name="lblInfoMsg" Text="..." Foreground="{DynamicResource TextBrush}" FontSize="12" FontFamily="Segoe UI" TextWrapping="Wrap" LineHeight="20"/>
                            </Border>
                            <!-- Buttons -->
                            <Grid Margin="0,20,0,0">
                                <Button x:Name="btnInfoOkError" Content="ПОНЯТНО" Click="InfoOk_Click" HorizontalAlignment="Center" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid>
                                                <Border x:Name="btnGlow" CornerRadius="8" Opacity="0.4">
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#ff7b72" BlurRadius="15" ShadowDepth="0" Opacity="0.5"/>
                                                    </Border.Effect>
                                                </Border>
                                                <Border x:Name="btnBg" Background="{DynamicResource BoxBrush}" CornerRadius="8" BorderBrush="{DynamicResource RedBrush}" BorderThickness="1.5" Padding="30,8">
                                                    <TextBlock Text="{TemplateBinding Content}" Foreground="{DynamicResource RedBrush}" FontFamily="Segoe UI" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="btnGlow" Property="Opacity" Value="0.7"/>
                                                    <Setter TargetName="btnBg" Property="Background" Value="#2a1218"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
        
                                <Button x:Name="btnInfoOkSuccess" Content="ПОНЯТНО" Click="InfoOk_Click" HorizontalAlignment="Center" Cursor="Hand" Visibility="Collapsed">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid>
                                                <Border x:Name="btnGlow" CornerRadius="8" Opacity="0.4">
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#2ea043" BlurRadius="15" ShadowDepth="0" Opacity="0.5"/>
                                                    </Border.Effect>
                                                </Border>
                                                <Border x:Name="btnBg" Background="{DynamicResource BoxBrush}" CornerRadius="8" BorderBrush="{DynamicResource GreenBrush}" BorderThickness="1.5" Padding="30,8">
                                                    <TextBlock Text="{TemplateBinding Content}" Foreground="{DynamicResource GreenBrush}" FontFamily="Segoe UI" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="btnGlow" Property="Opacity" Value="0.7"/>
                                                    <Setter TargetName="btnBg" Property="Background" Value="#1a2a1f"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════ -->
        <!-- SUCCESS INFO (зелёная версия)              -->
        <!-- Используется тот же WinInfo, цвет меняется -->
        <!-- программно в ShowInfo(isSuccess=true)       -->
        <!-- ═══════════════════════════════════════════ -->

        <!-- ═══════════════════════════════════════════ -->
        <!-- ALERT DIALOG (ДА / НЕТ)                   -->
        <!-- ═══════════════════════════════════════════ -->
        <Grid x:Name="WinAlert" Visibility="Collapsed" Width="380" VerticalAlignment="Center" HorizontalAlignment="Center">
            <!-- Shadow Layer -->
            <Border CornerRadius="12" Background="Transparent" BorderThickness="0" Margin="1.5">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="Black" Opacity="0.8"/>
                </Border.Effect>
            </Border>
            <!-- Background Layer -->
            <Border x:Name="WinAlertBg" CornerRadius="12" BorderThickness="1.5" Background="{DynamicResource DeepBgBrush}" BorderBrush="{DynamicResource GoldBrush}">
                <Grid>
                    <StackPanel Margin="0,12,0,20">
                        <!-- Header -->
                        <Grid Margin="15,0,15,10">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock x:Name="lblAlertTitle" Text="ВНИМАНИЕ" Foreground="{DynamicResource GoldBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                        <!-- Separator -->
                        <Line X1="15" Y1="0" X2="365" Y2="0" Stroke="{DynamicResource LineBrush}" StrokeThickness="1"/>
                        
                        <StackPanel Margin="25,20,25,0">
                            <!-- Message -->
                            <TextBlock x:Name="lblAlertMsg" Text="..." Foreground="{DynamicResource TextBrush}" FontSize="12" FontFamily="Segoe UI" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,20" LineHeight="20"/>
                            <!-- Buttons -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- ПОДТВЕРДИТЬ -->
                                <Button Grid.Column="0" Content="ПОДТВЕРДИТЬ" Click="AlertYes_Click" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid>
                                                <Border x:Name="btnGlow" CornerRadius="8" Opacity="0.5">
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#2ea043" BlurRadius="15" ShadowDepth="0" Opacity="0.5"/>
                                                    </Border.Effect>
                                                </Border>
                                                <Border x:Name="bg" Background="{DynamicResource BoxBrush}" CornerRadius="8" BorderBrush="{DynamicResource GreenBrush}" BorderThickness="1" Padding="0,10">
                                                    <TextBlock Text="{TemplateBinding Content}" Foreground="{DynamicResource GreenBrush}" FontFamily="Segoe UI" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="btnGlow" Property="Opacity" Value="0.8"/>
                                                    <Setter TargetName="bg" Property="Background" Value="#1a2a1f"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <!-- ОТМЕНА -->
                                <Button Grid.Column="2" Content="ОТМЕНА" Click="AlertNo_Click" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg" Background="{DynamicResource BoxBrush}" CornerRadius="8" BorderBrush="{DynamicResource RedBrush}" BorderThickness="1" Padding="0,10">
                                                <TextBlock Text="{TemplateBinding Content}" Foreground="{DynamicResource RedBrush}" FontFamily="Segoe UI" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="#2a1218"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════ -->
        <!-- INPUT DIALOG (ввод текста)                 -->
        <!-- ═══════════════════════════════════════════ -->
        <Grid x:Name="WinInputDlg" Visibility="Collapsed" Width="380" VerticalAlignment="Center" HorizontalAlignment="Center">
            <!-- Shadow Layer -->
            <Border CornerRadius="12" Background="Transparent" BorderThickness="0" Margin="1.5">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="Black" Opacity="0.8"/>
                </Border.Effect>
            </Border>
            <!-- Background Layer -->
            <Border x:Name="WinInputDlgBg" CornerRadius="12" BorderThickness="1.5" Background="{DynamicResource DeepBgBrush}" BorderBrush="{DynamicResource GoldBrush}">
                <Grid>
                    <StackPanel Margin="0,12,0,20">
                        <!-- Header -->
                        <Grid Margin="15,0,15,10">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock x:Name="lblInputTitle" Text="ВВОД" Foreground="{DynamicResource GoldBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button x:Name="btnSectionInfo" Content="ИНСТРУКЦИЯ" Click="BtnSectionInfo_Click" HorizontalAlignment="Right" Padding="6,2" Background="Transparent" Foreground="{DynamicResource GrayBrush}" BorderBrush="{DynamicResource GrayBrush}" BorderThickness="1" FontFamily="Segoe UI" FontSize="9" FontWeight="Bold" Cursor="Hand" Visibility="Collapsed">
                                <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                            </Button>
                        </Grid>
                        <!-- Separator -->
                        <Line X1="15" Y1="0" X2="365" Y2="0" Stroke="{DynamicResource LineBrush}" StrokeThickness="1"/>
                        
                        <StackPanel Margin="25,15,25,0">
                            <!-- Label -->
                            <TextBlock x:Name="lblInputLabel" Text="ВВЕДИТЕ НОВОЕ НАЗВАНИЕ" Foreground="{DynamicResource GrayBrush}" FontFamily="Segoe UI" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                            <!-- Input field -->
                            <Grid>
                                <TextBox x:Name="txtInputField" Height="42" Background="{DynamicResource SideBrush}" Foreground="{DynamicResource TextBrush}" BorderThickness="0" Padding="12,8" VerticalContentAlignment="Center" FontSize="14" FontFamily="Segoe UI" TextChanged="TxtInput_Changed">
                                    <TextBox.Resources>
                                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                                    </TextBox.Resources>
                                </TextBox>
                                <TextBlock x:Name="lblInputWatermark" Text="" Foreground="{DynamicResource GrayBrush}" Opacity="0.5" FontSize="14" FontFamily="Segoe UI" IsHitTestVisible="False" VerticalAlignment="Center" Margin="14,0,0,0" Visibility="Collapsed"/>
                            </Grid>
                            <!-- Section type selector (optional, shown for AddSection) -->
                            <StackPanel x:Name="pnlSectionType" Visibility="Collapsed" Margin="0,12,0,0">
                                <TextBlock Text="ВЫБЕРИТЕ ТИП РАЗДЕЛА:" Foreground="{DynamicResource GrayBrush}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Left" Margin="0,0,0,6"/>
                                <ComboBox x:Name="cbSectionType" Height="36" Style="{StaticResource DarkCombo}" Background="{DynamicResource SideBrush}" BorderBrush="{DynamicResource GoldBrush}" BorderThickness="1.5" Foreground="#ffffff" FontFamily="Segoe UI" FontSize="16" FontWeight="Bold" />


                            </StackPanel>
                            <!-- Hint -->
                            <TextBlock x:Name="lblInputHint" Text="" Foreground="{DynamicResource RedBrush}" Visibility="Collapsed" FontFamily="Segoe UI" FontSize="11" Margin="0,6,0,0" HorizontalAlignment="Center"/>
                            <!-- Buttons -->
                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- ПОДТВЕРДИТЬ -->
                                <Button Grid.Column="0" Content="ПОДТВЕРДИТЬ" Click="InputOk_Click" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid>
                                                <Border x:Name="btnGlow" CornerRadius="8" Opacity="0.5">
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#2ea043" BlurRadius="15" ShadowDepth="0" Opacity="0.5"/>
                                                    </Border.Effect>
                                                </Border>
                                                <Border x:Name="bg" Background="{DynamicResource BoxBrush}" CornerRadius="8" BorderBrush="{DynamicResource GreenBrush}" BorderThickness="1" Padding="0,10">
                                                    <TextBlock Text="{TemplateBinding Content}" Foreground="{DynamicResource GreenBrush}" FontFamily="Segoe UI" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="btnGlow" Property="Opacity" Value="0.8"/>
                                                    <Setter TargetName="bg" Property="Background" Value="#1a2a1f"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <!-- ОТМЕНА -->
                                <Button Grid.Column="2" Content="ОТМЕНА" Click="InputCancel_Click" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg" Background="{DynamicResource BoxBrush}" CornerRadius="8" BorderBrush="{DynamicResource RedBrush}" BorderThickness="1" Padding="0,10">
                                                <TextBlock Text="{TemplateBinding Content}" Foreground="{DynamicResource RedBrush}" FontFamily="Segoe UI" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="#2a1218"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
