                    <local:DialogHost x:Name="_dialogHost" Panel.ZIndex="1200" Grid.ColumnSpan="2" Grid.RowSpan="2"/>

                </Grid>  <!-- MainAppUI -->
            </Grid>  <!-- inner Grid -->
            </Border>  <!-- Border BgBrush -->
        </Grid>  <!-- MainBackgroundBorder -->
    </Grid>  <!-- Grid Margin=58 -->
</Window>
