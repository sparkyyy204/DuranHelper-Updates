                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                                            <!-- ═══════ PROFILE CARD ═══════ -->
                                            <Grid x:Name="dashProfileCard" Width="400" Height="200" Margin="0,0,30,0">
                                                <Border x:Name="dashProfileGlow" CornerRadius="16" Opacity="0" IsHitTestVisible="False">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#26d2a65e" Offset="0"/>
                                                            <GradientStop Color="#05d2a65e" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                                <Border x:Name="dashProfileBorder" Background="{DynamicResource SidebarBrush}" CornerRadius="16" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1.5">
                                                    <Border.Effect>
                                                        <DropShadowEffect RenderingBias="Performance" BlurRadius="16" ShadowDepth="12" Opacity="0.5" Color="Black"/>
                                                    </Border.Effect>
                                                    <Grid>
                                                        <Line X1="25" Y1="50" X2="375" Y2="50" Stroke="{DynamicResource LineBrush}" StrokeThickness="1" VerticalAlignment="Top"/>
                                                        <TextBlock Text="ТЕКУЩИЙ ПРОФИЛЬ" Foreground="{DynamicResource GrayBrush}" FontFamily="Segoe UI" FontSize="12" FontWeight="Bold" Margin="25,18,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"/>

                                                        <!-- Badge -->
                                                        <Border x:Name="dashProfileBadge" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,16,25,0" Width="95" Height="24" CornerRadius="12" Background="#1b1612" BorderBrush="{DynamicResource GoldBrush}" BorderThickness="1">
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <Ellipse x:Name="dashProfileDot" Width="8" Height="8" Fill="{DynamicResource GoldBrush}" Margin="0,0,5,0">
                                                                    <Ellipse.Effect><DropShadowEffect RenderingBias="Performance" BlurRadius="12" Color="#d2a65e" ShadowDepth="0" Opacity="0.8"/></Ellipse.Effect>
                                                                    <Ellipse.Triggers>
                                                                        <EventTrigger RoutedEvent="Loaded">
                                                                            <BeginStoryboard>
                                                                                <Storyboard RepeatBehavior="Forever">
