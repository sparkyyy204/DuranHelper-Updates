                        <TabControl.RenderTransform><TranslateTransform x:Name="Tabs_TT" X="0" Y="20" /></TabControl.RenderTransform>
                        <TabItem x:Name="tabDashboard">
                            <Grid Background="Transparent">

                                <!-- DASHBOARD: NO PROFILE (WIZARD PROMPT) -->
                                <!-- =================== UNIFIED DASHBOARD =================== -->
                                <Grid x:Name="pnlDashboard_Unified" Margin="30,25,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock x:Name="lblDashTitle" Text="ЦЕНТРАЛЬНАЯ ПАНЕЛЬ" Foreground="White" FontFamily="Segoe UI" FontSize="32" FontWeight="Bold"/>
