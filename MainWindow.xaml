                                <TextBlock Canvas.Left="0" Canvas.Top="54" Width="100" TextAlignment="Center" Text="ОБЛАКО" FontFamily="Segoe UI" FontWeight="Bold" FontSize="10" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
