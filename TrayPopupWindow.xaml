<Window x:Class="FSB_helper_C__.TrayPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True" ResizeMode="NoResize"
        Width="200" Height="100" Deactivated="Window_Deactivated"
        UseLayoutRounding="True" SnapsToDevicePixels="True">
    <Border x:Name="rootBorder" CornerRadius="10" Background="{DynamicResource SideBrush}" 
            BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Margin="8"
            RenderTransformOrigin="0.5,1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.5" Color="Black"/>
        </Border.Effect>
        <Border.RenderTransform>
            <ScaleTransform x:Name="scaleTransform" ScaleX="1" ScaleY="1"/>
        </Border.RenderTransform>
        <StackPanel Margin="6">
            <Button x:Name="btnShow" Content="⬜  Развернуть" 
                    Height="32" Background="Transparent" Foreground="{DynamicResource TextBrush}"
                    BorderThickness="0" Cursor="Hand"
                    FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                    HorizontalContentAlignment="Left" Padding="12,0"
                    Click="BtnShow_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource MenuHoverBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
            <Border Height="1" Background="{DynamicResource LineBrush}" Margin="10,3" Opacity="0.6"/>
            <Button x:Name="btnClose" Content="✕  Закрыть" 
                    Height="32" Background="Transparent" Foreground="{DynamicResource RedBrush}"
                    BorderThickness="0" Cursor="Hand"
                    FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                    HorizontalContentAlignment="Left" Padding="12,0"
                    Click="BtnClose_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource MenuHoverBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Border>
</Window>
